      "source": [
        "def fact(n):\n",
        "  if n==0:\n",
        "    return 1\n",
        "  return n*fact(n-1)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def gamma(n):\n",
        "  return fact(n-1)"
      ],
      "metadata": {
        "id": "qvXrOAnPfdtZ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def beta(m,n):\n",
        "  return(gamma(m)*gamma(n))/gamma(m+n)"
      ],
      "metadata": {
        "id": "ph7Y-oNNfbHh"
      },
      "execution_count": null,
      "outputs": []
    },
